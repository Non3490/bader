# DATABASE_URL=file:./dev.db  # For local development with SQLite
# DATABASE_URL=postgresql://user:password@host:port/database  # For production (PostgreSQL/Neon)
DATABASE_URL=

# Application URL (required for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Secret for authentication (REQUIRED in production, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google Sheets API Configuration
# Get from: https://console.cloud.google.com/apis/credentials
# Create a Service Account and download the JSON key file
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Pusher for real-time notifications
PUSHER_APP_ID=
PUSHER_KEY=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Twilio for voice calls and SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=

# Google Maps for GPS delivery zones (optional)
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
