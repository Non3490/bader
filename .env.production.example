# ==========================================
# Gabon COD Platform - Production Environment
# ==========================================

# Database - Vercel Postgres
# Get this from Vercel Dashboard > Storage > Postgres
DATABASE_URL=postgresql://user:password@ep-xxx.region.ama.zons.aws.com:5432/verceldb?pgbouncer=true

# Database Pooling (recommended for Vercel)
DIRECT_URL=postgresql://user:password@ep-xxx.region.ama.zons.aws.com:5432/verceldb

# NextAuth / Authentication
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=your-production-secret-key-min-32-chars

# JWT Secret
JWT_SECRET=your-production-jwt-secret-min-32-chars

# Twilio Configuration (SMS/Voice)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Cloudinary Configuration (Image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Pusher Configuration (Real-time updates)
PUSHER_APP_ID=xxxxxx
PUSHER_KEY=xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PUSHER_KEY=xxxxxxxxxxxxxxxxxxxx
PUSHER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUSHER_CLUSTER=mt1
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# Google Sheets API Configuration
GOOGLE_SHEETS_CLIENT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Carrier APIs
SHIPSEN_API_KEY=xxxxxxxxxxx
COLISSWIFT_API_KEY=xxxxxxxxxxx
AFRIQUECOD_API_KEY=xxxxxxxxxxx

# Application URL (for webhooks & callbacks)
APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
